# Gemini API Keys (rotate to avoid rate limits)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY_2=optional_backup_key
GEMINI_API_KEY_3=optional_backup_key
GEMINI_API_KEY_4=optional_backup_key
GEMINI_API_KEY_5=optional_backup_key
GEMINI_API_KEY_6=optional_backup_key
GEMINI_API_KEY_7=optional_backup_key
GEMINI_API_KEY_8=optional_backup_key
GEMINI_API_KEY_9=optional_backup_key

# NVIDIA NIM API Key (uses the OpenAI-compatible endpoint at integrate.api.nvidia.com/v1)
NVIDIA_API_KEY=your_nvidia_nim_key_here

# Groq API Key (last fallback; free tier daily token limits can be exhausted)
GROQ_API_KEY=your_groq_key_here
